{
    "name": "nerofann/config",
    "repositories": [
        {
            "type": "vcs", 
            "url": "https://github.com/DevTeam-AllMediaIndo/shared-module.git"
        }
    ],
    "require": {
        "phpmailer/phpmailer": "^6.10",
        "ozdemir/datatables": "^2.3",
        "vlucas/phpdotenv": "^5.6",
        "aws/aws-sdk-php": "^3.349",
        "allmedia/shared-module": "^1.0",
        "dompdf/dompdf": "^3.1",
        "kreait/firebase-php": "^6.0",
        "mailgun/mailgun-php": "^4.3",
        "nesbot/carbon": "^3.11",
        "phpoffice/phpspreadsheet": "^5.7"
    },
    "autoload": {
        "psr-4": {
            "Config\\Core\\": "core/",
            "App\\Models\\": "models/",
            "App\\Factory\\": "factory/",
            "App\\PaymentSystem\\": "PaymentSystem/",
            "App\\Library\\": "library/",
            "App\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Fani Annur Rozi",
            "email": "crazyhx4@gmail.com"
        }
    ],
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    }
}
